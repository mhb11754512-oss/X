# AI Provider Configuration
AI_PROVIDER=groq

# App / deployment settings
SECRET_KEY=change_me
JWT_SECRET=change_me
DATABASE_PATH=database/project_x.db
UPLOAD_FOLDER=uploads
LOG_FILE_PATH=logs/project_x.log
HOST=0.0.0.0
PORT=5000
ENABLE_CLOUDFLARED_TUNNEL=0
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_TTL_HOURS=12

# API Keys (Replace with your actual keys)
XAI_API_KEY=your_xai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
NGROK_AUTH_TOKEN=your_ngrok_token_here
HF_API_KEY=your_huggingface_api_key_here
WAWP_ACCESS_TOKEN=your_wawp_access_token_here
WAWP_INSTANCE_ID=your_wawp_instance_id_here
WAWP_WEBHOOK_SECRET=your_wawp_webhook_secret_here
WAWP_SITE_VISITOR_NOTIFY_NUMBER=your_phone_number_here
WAWP_SITE_VISITOR_NOTIFY_NUMBERS=

# AI Model Configuration
XAI_MODEL=grok-3-latest
XAI_BASE_URL=https://api.x.ai/v1

GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

HF_MODEL=deepseek-ai/DeepSeek-R1:fastest
HF_BASE_URL=https://router.huggingface.co/v1
